+;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
+;; polynomial wmc ffi
+
+(define-cpointer-type _rsdd_poly_weight)
+(define-cpointer-type _rsdd_wmc_params_poly)
+
+;; Layout must match Rust struct:
+;; pub struct WeightPoly { low: *mut PolyWeight, high: *mut PolyWeight }
+(define-cstruct _weight_poly
+  ([low _rsdd_poly_weight]
+   [high _rsdd_poly_weight]))
+
+(define-rsdd new-wmc-params-poly
+  (_fun -> _rsdd_wmc_params_poly))
+
+;; Rust: fn new_polynomial(coeffs: *const f64, len: usize) -> *mut PolyWeight
+;; CHANGE: Use _pointer instead of _list to avoid syntax errors
+(define-rsdd new-polynomial
+  (_fun _pointer _size -> _rsdd_poly_weight))
+
+(define-rsdd destroy-polynomial
+  (_fun _rsdd_poly_weight -> _void))
+
+;; Rust: fn wmc_param_poly_set_weight(...)
+;; CHANGE: Use _pointer instead of _list
+(define-rsdd wmc-param-poly-set-weight
+  (_fun _rsdd_wmc_params_poly _uint64
+        _pointer _size
+        _pointer _size
+        -> _void))
+
+(define-rsdd polynomial-len
+  (_fun _rsdd_poly_weight -> _size))
+
+;; Rust: fn polynomial_get_coeffs(p: *const PolyWeight, out: *mut f64, max: usize) -> usize
+(define-rsdd polynomial-get-coeffs
+  (_fun _rsdd_poly_weight _pointer _size -> _size))
+
+(define-rsdd bdd-wmc-poly
+  (_fun _rsdd_bdd_ptr _rsdd_wmc_params_poly -> _rsdd_poly_weight))
+
+;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
+;; polynomial helpers
+
+;; Helper: Convert Racket list of numbers to a C array of doubles
+;;(define (list->c-double-array lst)
+;;  (define len (length lst))
+;;  (define ptr (malloc _double len)) ; Allocate C memory
+;;  (for ([val (in-list lst)]
+;;        [i (in-naturals)])
+;;    (ptr-set! ptr _double i (exact->inexact val)))
+;;  ptr)
+
+(define (list->c-double-array lst)
+  (define len (length lst))
+  (define ptr (malloc _double len 'raw))
+  (for ([val (in-list lst)]
+        [i (in-naturals)])
+    (ptr-set! ptr _double i (exact->inexact val)))
+  ptr)
+
+(define (list->poly coeffs)
+  ;; Marshal list to C array
+  (define ptr (list->c-double-array coeffs))
+  (new-polynomial ptr (length coeffs)))
+
+(define (poly->list poly-ptr)
+  (cond
+    [(or (not poly-ptr) (ptr-equal? poly-ptr #f)) '()]
+    [else
+     (define len (polynomial-len poly-ptr))
+     (define out-arr (malloc _double len))
+     (polynomial-get-coeffs poly-ptr out-arr len)
+     (for/list ([i (in-range len)])
+       (ptr-ref out-arr _double i))]))
+
+;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
+;; polynomial wrappers
+
+(define-wrap rsdd-polynomial-wmc
+  #:from (lambda (ws ptr)
+           (define poly-ptr (bdd-wmc-poly ptr ws))
+           (begin0
+             (poly->list poly-ptr)
+             (destroy-polynomial poly-ptr)))
+  #:target POLY-WEIGHTS
+  #:fields ptr)
+
+(define-wrap rsdd-set-polynomial-measure!
+  #:from (lambda (ws lab lo hi)
+           (define lo-lst (if (list? lo) lo (list lo)))
+           (define hi-lst (if (list? hi) hi (list hi)))
+           ;; Marshal both lists to C arrays
+           (define lo-ptr (list->c-double-array lo-lst))
+           (define hi-ptr (list->c-double-array hi-lst))
+           
+           (wmc-param-poly-set-weight ws lab
+                                      lo-ptr (length lo-lst)
+                                      hi-ptr (length hi-lst)))
+  #:target POLY-WEIGHTS
+  #:fields label lo hi)
+
+;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
+;; polynomial semiring implementation
+
+(define POLY-WEIGHTS (new-wmc-params-poly))
+
+(define (polynomial? v)
+  (and (list? v)
+       ;;(and (not (null? v))
+            (andmap number? v)))
+
+(define (poly-plus p1 p2)
+  (let loop ([p1 p1] [p2 p2])
+    (match* (p1 p2)
+      [('() '()) '()]
+      [('() p2) p2]
+      [(p1 '()) p1]
+      [((cons c1 r1) (cons c2 r2))
+       (cons (+ c1 c2) (loop r1 r2))])))
+
+(define polynomial-semiring
+  (semiring
+   polynomial?                  ; predicate
+   '()                          ; zero
+   poly-plus                    ; plus
+   rsdd-set-polynomial-measure! ; var-set!
+   rsdd-polynomial-wmc))        ; wmc
+
