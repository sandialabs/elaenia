diff --git a/roulette/test/test-poly.rkt b/roulette/test/test-poly.rkt
new file mode 100644
index 0000000..696530c
--- /dev/null
+++ b/roulette/test/test-poly.rkt
@@ -0,0 +1,26 @@
+#lang roulette
+(require roulette/engine/rsdd
+         racket/set)
+
+;; Required for define-measurable
+(require roulette) 
+
+(printf "Semiring loaded: ~a\n" polynomial-semiring)
+
+(define (flip-poly)
+  ;; 'infer' scans for symbolic variables to decide which weights to send to Rust.
+  (define-measurable x 
+    (bernoulli-measure '(0.5 0.5) 
+                       '(0.5 0.5) 
+                       #:semiring polynomial-semiring))
+  x)
+
+;; Explicitly use the polynomial engine
+(define result 
+  (infer (flip-poly) 
+         #:engine (rsdd-engine #:semiring polynomial-semiring)))
+
+(printf "Inference Result:\n")
+(for ([val '(#t #f)])
+  (define prob (result (set val)))
+  (printf "Val: ~a | Prob (coeffs): ~a\n" val prob))
