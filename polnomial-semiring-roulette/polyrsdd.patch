+unsafe extern "C" fn new_polynomial(coeffs: *const f64, len: usize) -> *mut PolyWeight {
+    let poly = from_c_parts(coeffs, len);
+    Box::into_raw(Box::new(poly))
+}
+
+#[no_mangle]
+unsafe extern "C" fn destroy_polynomial(p: *mut PolyWeight) {
